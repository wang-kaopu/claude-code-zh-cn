      "allowedEnglishLineRegexes": [
        "^\\s*[a-z][a-z0-9-]*(\\|[a-z][a-z0-9-]*)?(\\s+\\[[^\\]]+\\])?$",
        "^\\s*claude\\s+.*$",
        "^\\s*--file\\s+file_[a-z]+:[A-Za-z0-9_.-]+(?:\\s+file_[a-z]+:[A-Za-z0-9_.-]+)?[）)]?$",
        "^\\s*file_[a-z]+:[A-Za-z0-9_.-]+[）)]?$"
      ],
      "minEnglishWords": 2,
      "maxUntranslatedLines": 0
    }

{
  "packageName": "@anthropic-ai/claude-code",
  "baseline": {
    "versions": [
      "2.1.92",
      "2.1.97",
      "2.1.104",
      "2.1.107",
      "2.1.110",
      "2.1.112"
    ],
    "includeLatestFromNpm": false
  },
  "checks": {
    "sentinels": [
      {
        "id": "quick_safety_check",
        "pattern": "Quick safety check"
      },
      {
        "id": "security_guide",
        "pattern": "Security guide"
      },
      {
        "id": "btw_prompt",
        "pattern": "Use /btw to ask a quick side question without interrupting Claude's current work"
      },
      {
        "id": "approval_reason",
        "pattern": "This command requires approval"
      },
      {
        "id": "proceed_prompt",
        "pattern": "Do you want to proceed?"
      },
      {
        "id": "tab_to_amend",
        "pattern": "Tab to amend"
      },
      {
        "id": "ctrl_e_to_explain",
        "pattern": "ctrl+e to explain"
      },
      {
        "id": "native_permission_title_unsandboxed_residue",
        "pattern": "Bash command (unsandboxed)"
      },
      {
        "id": "native_permission_waiting_escaped",
        "pattern": "Waiting\\u2026"
      }
    ],
    "templateResidues": [
      {
        "id": "duration_worked",
        "pattern": "Worked for"
      },
      {
        "id": "duration_idle",
        "pattern": "Idle for"
      },
      {
        "id": "duration_guarded",
        "regex": "&&`\\$\\{[^}]+\\} for \\$\\{[^}]+\\}`"
      },
      {
        "id": "duration_literal_connector",
        "regex": ",\\s*\" for \"\\s*,"
      }
    ],
    "upstreamTextGuards": [
      {
        "id": "advisor_prompt_tool_name",
        "rule": "preserve",
        "pattern": "# Advisor Tool\n\nYou have access to an \\`advisor\\` tool"
      },
      {
        "id": "advisor_dialog_title",
        "rule": "preserve",
        "pattern": "title:\"Advisor Tool\""
      },
      {
        "id": "system_prompt_short_concise",
        "rule": "preserve",
        "pattern": "Your responses should be short and concise."
      },
      {
        "id": "system_prompt_memory_contract",
        "rule": "preserve",
        "pattern": "Saving a memory is a two-step process:"
      },
      {
        "id": "system_prompt_environment_header",
        "rule": "preserve",
        "pattern": "You have been invoked in the following environment:"
      },
      {
        "id": "statusline_setup_agent_prompt",
        "rule": "preserve",
        "pattern": "You are a status line setup agent for Claude Code."
      },
      {
        "id": "statusline_setup_home_path_guard",
        "rule": "preserve",
        "sourcePattern": "You are a status line setup agent for Claude Code.",
        "pattern": "Never invent or guess an absolute /Users/... path"
      },
      {
        "id": "statusline_command_agent_prompt_path_guard",
        "rule": "preserve",
        "sourcePattern": "with subagent_type \"statusline-setup\" and the prompt",
        "pattern": "when calling Read, Edit, or Write"
      },
      {
        "id": "native_permission_title",
        "rule": "translate",
        "sourcePattern": "\"Bash command (unsandboxed)\":\"Bash command\"",
        "pattern": "\"Bash 命令（未沙盒隔离）\":\"Bash 命令\""
      },
      {
        "id": "native_permission_yes_option_label",
        "rule": "translate",
        "sourcePattern": "label:\"Yes\",value:\"yes\"",
        "pattern": "label:\"是\",value:\"yes\""
      },
      {
        "id": "native_permission_no_option_label",
        "rule": "translate",
        "sourcePattern": "label:\"No\",value:\"no\"",
        "pattern": "label:\"否\",value:\"no\""
      },
      {
        "id": "native_permission_dont_ask_again_prefix",
        "rule": "translate",
        "sourceRegex": "Yes, and don(?:\\\\u2019|[’'])t ask again for",
        "pattern": "label:\"是，不再询问\""
      },
      {
        "id": "compact_duration_zero_seconds",
        "rule": "translate",
        "sourceRegex": "if\\([A-Za-z0-9_$]+<60000\\)\\{if\\([A-Za-z0-9_$]+===0\\)return\"0s\"",
        "regex": "if\\([A-Za-z0-9_$]+<60000\\)\\{if\\([A-Za-z0-9_$]+===0\\)return\"0秒\""
      },
      {
        "id": "compact_duration_template_units",
        "rule": "translate",
        "sourceRegex": "mostSignificantOnly[\\s\\S]*?return`\\$\\{[^}]+\\}d`[\\s\\S]*?return`\\$\\{[^}]+\\}h`[\\s\\S]*?return`\\$\\{[^}]+\\}m`[\\s\\S]*?return`\\$\\{[^}]+\\}s`",
        "regex": "mostSignificantOnly[\\s\\S]*?return`\\$\\{[^}]+\\}天`[\\s\\S]*?return`\\$\\{[^}]+\\}时`[\\s\\S]*?return`\\$\\{[^}]+\\}分`[\\s\\S]*?return`\\$\\{[^}]+\\}秒`"
      },
      {
        "id": "web_search_exact_terms_contract",
        "rule": "preserve",
        "pattern": "Use exact search terms without * or ?"
      },
      {
        "id": "stop_ultrareview_label",
        "rule": "translate",
        "sourcePattern": "label:\"Stop ultrareview\"",
        "pattern": "label:\"停止 ultrareview\""
      },
      {
        "id": "ultrareview_billing_template",
        "rule": "template",
        "sourceRegex": "body:`This review bills as Extra Usage \\(\\$\\{[^}]+\\}\\)\\.`",
        "regex": "body:`本次 review 会按 Extra Usage 计费（\\$\\{[^}]+\\}）。`"
      },
      {
        "id": "ultrareview_launch_template",
        "rule": "template",
        "sourceRegex": "text:`\\$\\{[^}]+\\}Ultrareview launched for \\$\\{[^}]+\\} \\(\\$\\{[^}]+\\}, runs in the cloud\\)\\. Track: \\$\\{[^}]+\\}\\$\\{[^}]+\\}`",
        "regex": "text:`\\$\\{[^}]+\\}Ultrareview 已为 \\$\\{[^}]+\\} 启动（\\$\\{[^}]+\\}，云端运行）。跟踪：\\$\\{[^}]+\\}\\$\\{[^}]+\\}`"
      },
      {
        "id": "issue80_jetbrains_install_notice",
        "rule": "translate",
        "sourcePattern": " plugin from the JetBrains Marketplace:",
        "pattern": "从 JetBrains Marketplace 安装 "
      },
      {
        "id": "issue80_model_switch_notice",
        "rule": "template",
        "sourcePattern": " and saved as your default for new sessions",
        "pattern": "已切换模型为 "
      },
      {
        "id": "issue80_model_session_scope_notice",
        "rule": "translate",
        "sourcePattern": " for this session only. Selecting a model will undo this.",
        "pattern": "（仅本次会话）。选择模型将取消此设置。"
      },
      {
        "id": "issue80_code_review_command_description",
        "rule": "template",
        "sourcePattern": "Review the current diff for correctness bugs and reuse/simplification/efficiency cleanups at the given effort level",
        "pattern": "审查当前 diff 的正确性问题"
      },
      {
        "id": "issue80_simplify_command_description",
        "rule": "translate",
        "sourcePattern": "Review the current diff and apply the fixes \\u2014 equivalent to /code-review --fix.",
        "pattern": "审查当前 diff 并应用修复，相当于 /code-review --fix。"
      },
      {
        "id": "issue80_advisor_command_description",
        "rule": "translate",
        "sourcePattern": "Configure the Advisor Tool to consult a stronger model for guidance at key moments during a task",
        "pattern": "配置 Advisor Tool，在任务关键节点咨询更强模型获取建议"
      },
      {
        "id": "issue80_background_command_description",
        "rule": "translate",
        "sourcePattern": "Send this session to the background and free the terminal",
        "pattern": "将本会话放到后台并释放终端"
      },
      {
        "id": "issue80_clear_command_description",
        "rule": "translate",
        "sourcePattern": "Start a new session with empty context; previous session stays on disk (resumable with /resume)",
        "pattern": "用空上下文开始新会话；之前的会话会保留在磁盘上（可用 /resume 恢复）"
      },
      {
        "id": "issue80_exit_cli_description",
        "rule": "translate",
        "sourcePattern": "Exit the CLI",
        "pattern": "退出 CLI"
      },
      {
        "id": "issue80_exit_background_description",
        "rule": "translate",
        "sourcePattern": "Detach from this background session (it keeps running)",
        "pattern": "从这个后台会话断开（会话会继续运行）"
      },
      {
        "id": "issue80_fast_dynamic_description",
        "rule": "template",
        "sourceRegex": "Toggle fast mode \\(\\$\\{[^}]+\\}\\)",
        "regex": "切换快速模式（\\$\\{[^}]+\\}）"
      },
      {
        "id": "issue80_fast_dynamic_only_description",
        "rule": "template",
        "sourceRegex": "Toggle fast mode \\(\\$\\{[^}]+\\} only\\)",
        "regex": "切换快速模式（仅 \\$\\{[^}]+\\}）"
      },
      {
        "id": "issue80_fast_concrete_description",
        "rule": "template",
        "sourceRegex": "Toggle fast mode \\(Opus [^)]+\\)",
        "regex": "切换快速模式（(?:仅 )?Opus [^)]+）"
      },
      {
        "id": "issue80_feedback_command_description_v2",
        "rule": "translate",
        "sourcePattern": "Submit feedback, report a bug, or share your conversation",
        "pattern": "提交反馈、报告问题或分享你的对话"
      },
      {
        "id": "issue80_focus_command_description",
        "rule": "translate",
        "sourcePattern": "Toggle focus view (show only your prompt, a tool summary, and the final response)",
        "pattern": "切换专注视图（只显示你的提示词、工具摘要和最终回复）"
      },
      {
        "id": "issue80_goal_command_description",
        "rule": "translate",
        "sourcePattern": "Set a goal \\u2014 keep working until the condition is met",
        "pattern": "设置目标：持续工作直到条件满足"
      }
    ],
